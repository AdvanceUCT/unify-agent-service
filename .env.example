# =============================================================================
# Identity Agent Service — environment configuration
# =============================================================================
#
# HOW TO USE THIS FILE
#   1. Copy this file to `.env`:           cp .env.example .env
#   2. Read the comments below
#   3. For local dev you usually don't need to change anything except possibly
#      AGENT_WALLET_KEY (and even that is optional — see notes)
#   4. Run:                                 docker compose up --build
#
# IF YOU CHANGE A VALUE AND THE AGENT WON'T BOOT
#   Most likely cause: you changed AGENT_WALLET_KEY after a wallet was already
#   created with the old key. Credo can't decrypt the existing wallet with a
#   different key, so it refuses to start.
#   Fix:                                    docker compose down -v
#                                           docker compose up --build
#   (the `-v` wipes the wallet volume so a fresh wallet is created)
#
# =============================================================================


# -----------------------------------------------------------------------------
# Agent identity
# -----------------------------------------------------------------------------

# Human-readable label this agent advertises in DIDComm handshakes and that
# appears in log lines. Other agents (e.g. student wallets) see this label
# during the connection handshake.
#
# LEAVE AS DEFAULT for local dev. In production set it to something
# recognisable to students, e.g. "University of Cape Town".
AGENT_NAME=university-identity-agent


# Logical wallet identifier. Becomes the name of the SQLite database file
# inside the wallet volume:
#   /home/node/.afj/data/wallet/<AGENT_WALLET_ID>/sqlite.db
#
# LEAVE AS DEFAULT unless you have a specific reason to run two wallets
# side-by-side on the same machine (you almost never do).
AGENT_WALLET_ID=university-agent-wallet


# Passphrase that derives (via Argon2) the AES key used to encrypt the wallet.
#
# WHAT TO USE FOR IT
#   Local dev:  Any string you like, ≥ 8 characters. The default below is
#               fine — the wallet contains nothing valuable yet.
#   Staging:    A high-entropy random string. Generate with e.g.
#                   openssl rand -base64 32
#               Store it in your team's secret manager, NOT in git.
#   Production: Same as staging, but additionally back it up to the secret
#               manager BEFORE running the issuer-DID creation flow. Once
#               your university's issuer DID is on the ledger, losing this
#               key means losing the ability to sign as that DID — forever.
#
# DO TEAM MEMBERS NEED THE SAME VALUE?
#   No. Each developer has their own Docker volume. Your wallet is yours;
#   your teammate's wallet is theirs. Pick whatever you like locally.
#
# DOES IT MATTER WHAT VALUE I PICK?
#   Right now: no — the wallet is effectively empty and BCovrin Test is a
#   public test ledger. The current dev default is genuinely fine.
#   After implementing the issuer-DID feature: yes — the wallet now contains
#   a real Ed25519 signing key. Lose this key, lose your university's identity.
#
# CAN I CHANGE IT LATER?
#   Yes, but: changing it after a wallet has already been created causes the
#   next boot to fail (Credo can't decrypt the existing wallet with a new
#   key). You must wipe the volume first:
#       docker compose down -v
#       docker compose up --build
AGENT_WALLET_KEY=change-this-to-a-secure-key


# -----------------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------------

# The public DIDComm endpoint advertised inside Out-of-Band invitations and
# the issuer's DID document. Other agents (most importantly student wallets
# on phones) will reach the agent at this URL.
#
# LOCAL DEV with no external wallet
#   Leave as `http://localhost:3001`. Useful for unit-testing the API and
#   running both ends locally.
#
# LOCAL DEV with a real phone running the student wallet app
#   localhost won't be reachable from the phone. Use ngrok or similar to
#   expose port 3001:
#       ngrok http 3001
#   Then set AGENT_ENDPOINT to the https://...ngrok-free.app URL it gives you.
#
# PRODUCTION
#   Set to your public HTTPS URL, e.g. https://identity-agent.uct.ac.za
AGENT_ENDPOINT=http://localhost:3001


# Port the agent's inbound DIDComm transport binds to (HTTP).
# Must match the port in AGENT_ENDPOINT.
#
# LEAVE AS DEFAULT unless 3001 conflicts with another service on your machine.
# If you change it, also update docker-compose.yml port mapping AND
# AGENT_ENDPOINT to match.
AGENT_PORT=3001


# Port the Express REST API binds to. This is the API the Admin Portal calls.
# Internal-only — never directly accessed by student wallets.
#
# LEAVE AS DEFAULT unless 3000 conflicts. If you change it, also update
# docker-compose.yml port mapping.
API_PORT=3000


# -----------------------------------------------------------------------------
# Admin Portal integration (optional)
# -----------------------------------------------------------------------------

# Webhook URL the agent will POST to whenever a connection or credential
# state changes (e.g. a student's wallet has accepted a credential offer).
# The Admin Portal exposes this endpoint and uses the events to update the
# issuance status table in real time.
#
# LEAVE COMMENTED OUT for local dev unless you're actively integrating with
# a running Admin Portal. When unset, state changes are logged to stdout only.
#
# When you uncomment this, see `src/events/connectionEvents.ts` and
# `src/events/credentialEvents.ts` — the dispatch logic is currently a TODO
# stub waiting to be implemented.
# WEBHOOK_URL=http://admin-portal:4000/internal/agent-events
