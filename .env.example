# Copy this file to `.env`, then start Docker.
#   cp .env.example .env
#   docker compose up --build
#
# If AGENT_WALLET_KEY changes, reset the local wallet volume.
#   docker compose down -v


# -----------------------------------------------------------------------------
# Agent identity
# -----------------------------------------------------------------------------

AGENT_NAME=university-identity-agent

AGENT_WALLET_ID=university-agent-wallet

AGENT_WALLET_KEY=change-this-to-a-secure-key


# -----------------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------------

AGENT_ENDPOINT=http://localhost:3001

AGENT_PORT=3001

API_PORT=3002

AGENT_API_KEY=dev-agent-api-key

TAILS_BASE_URL=http://localhost:3002/tails

TAILS_DIRECTORY=/home/node/.afj/tails


# -----------------------------------------------------------------------------
# Tokenized wallet activation links
# -----------------------------------------------------------------------------

WALLET_ACTIVATION_ROUTE=unifywallet://activate
ACTIVATION_TOKEN_TTL_HOURS=24
ACTIVATION_ISSUER_LABEL="UNIFY Issuer Service"

ACTIVATION_STORE_FILE=/home/node/.afj/activation-links.json


# -----------------------------------------------------------------------------
# Legacy/demo issuance fallback values
# -----------------------------------------------------------------------------

DEMO_CREDENTIAL_DEFINITION_ID=
DEMO_ISSUER_LABEL="UNIFY Issuer Service"
DEMO_LEDGER_NAME="BCovrin Test"


# -----------------------------------------------------------------------------
# Admin Portal integration
# -----------------------------------------------------------------------------

WEBHOOK_URL=

WEBHOOK_SIGNING_SECRET=
