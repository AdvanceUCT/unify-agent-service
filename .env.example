


# LEAVE AS DEFAULT for local dev. In production set it to something
# recognisable to students, e.g. "University of Cape Town".
AGENT_NAME=university-identity-agent


# Logical wallet identifier. Becomes the name of the SQLite database file
# inside the wallet volume:
#   /home/node/.afj/data/wallet/<AGENT_WALLET_ID>/sqlite.db
#
# LEAVE AS DEFAULT unless you have a specific reason to run two wallets
# side-by-side on the same machine (you almost never do).
AGENT_WALLET_ID=university-agent-wallet



AGENT_WALLET_KEY=change-this-to-a-secure-key


# -----------------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------------


#
# PRODUCTION
#   Set to your public HTTPS URL, e.g. https://identity-agent.uct.ac.za
AGENT_ENDPOINT=http://localhost:3001


# Port the agent's inbound DIDComm transport binds to (HTTP).
# Must match the port in AGENT_ENDPOINT.
#
# LEAVE AS DEFAULT unless 3001 conflicts with another service on your machine.
# docker-compose.yml reads this value for the host/container port mapping.
# If you change it, also update AGENT_ENDPOINT to match.
AGENT_PORT=3001


# Port the Express REST API binds to. This is the API the Admin Portal calls.
# Internal-only — never directly accessed by student wallets.
#
# LEAVE AS DEFAULT unless 3002 conflicts. docker-compose.yml reads this value
# for the host/container port mapping.
API_PORT=3002


# Shared bearer token the Admin Portal must send when calling the agent API.
# Local dev default is intentionally simple; replace it outside local Docker.
AGENT_API_KEY=dev-agent-api-key



TAILS_BASE_URL=http://localhost:3002/tails

# Local directory where generated tails files are persisted. In Docker the
# default resolves under /home/node/.afj/tails, which is covered by the
# existing agent-data volume.
TAILS_DIRECTORY=/home/node/.afj/tails


# -----------------------------------------------------------------------------
# Tokenized wallet activation links
# -----------------------------------------------------------------------------


WALLET_ACTIVATION_ROUTE=unifywallet://activate
ACTIVATION_TOKEN_TTL_HOURS=24
ACTIVATION_ISSUER_LABEL="UNIFY Issuer Service"

# Persisted activation-token store. In Docker the default sits under /home/node
# and is covered by the existing agent-data volume.
ACTIVATION_STORE_FILE=/home/node/.afj/activation-links.json


# -----------------------------------------------------------------------------
# Legacy/demo issuance fallback values
# -----------------------------------------------------------------------------

# These are only used by older demo helpers. The admin portal MVP supplies the
# real credential definition id from setup state when issuing activation links.
DEMO_CREDENTIAL_DEFINITION_ID=
DEMO_ISSUER_LABEL="UNIFY Issuer Service"
DEMO_LEDGER_NAME="BCovrin Test"



WEBHOOK_URL=

# Optional HMAC signing secret for webhook requests. When set, requests include:
#   X-Unify-Signature: sha256=<hex-hmac-of-json-body>
WEBHOOK_SIGNING_SECRET=
